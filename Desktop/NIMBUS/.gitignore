# Ignore the local Python virtual environment because it is rebuilt from requirements.txt.
.venv/

# Ignore Python cache folders because Python creates them automatically while code runs.
__pycache__/

# Ignore compiled Python files because they are generated by Python, not written by humans.
*.pyc

# Ignore local environment files because they often contain secrets like AWS profile names or keys.
.env

# Ignore AWS credential folders in case one is accidentally copied into this project.
.aws/

# Ignore processed reports for now because future scripts will generate these files again.
reports/

# Keep raw learning data local because CloudTrail logs can contain account details and IP addresses.
data/raw/*

# Keep the raw data folder itself so the project layout is visible even when logs are ignored.
!data/raw/.gitkeep

# Keep processed data local because future parsing steps will generate it from raw logs.
data/processed/*

# Keep the processed data folder itself so the project layout is visible even when outputs are ignored.
!data/processed/.gitkeep
